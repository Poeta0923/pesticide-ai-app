{
  "uid": "pesticide-backend",
  "title": "Pesticide Backend",
  "tags": ["pesticide", "nestjs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Backend 상태",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"nestjs-backend\"}", "refId": "A", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "프로세스 가동 시간",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "time() - process_start_time_seconds{app=\"pesticide-backend\"}", "refId": "A", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "현재 메모리 (RSS)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_resident_memory_bytes{app=\"pesticide-backend\"}", "refId": "A", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU 사용률 (1분 평균)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(process_cpu_user_seconds_total{app=\"pesticide-backend\"}[1m])",
          "refId": "user",
          "legendFormat": "user"
        },
        {
          "expr": "rate(process_cpu_system_seconds_total{app=\"pesticide-backend\"}[1m])",
          "refId": "system",
          "legendFormat": "system"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "메모리 사용량",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{app=\"pesticide-backend\"}",
          "refId": "rss",
          "legendFormat": "RSS"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{app=\"pesticide-backend\"}",
          "refId": "heap_used",
          "legendFormat": "Heap used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{app=\"pesticide-backend\"}",
          "refId": "heap_total",
          "legendFormat": "Heap total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "이벤트 루프 지연 (Event Loop Lag)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{app=\"pesticide-backend\"}",
          "refId": "lag",
          "legendFormat": "current"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{app=\"pesticide-backend\"}",
          "refId": "p99",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Node.js Heap 영역별 사용량",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nodejs_heap_space_size_used_bytes{app=\"pesticide-backend\"}",
          "refId": "A",
          "legendFormat": "{{space}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Backend 로그",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{app=\"pesticide-backend\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
